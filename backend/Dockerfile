FROM python:3.12-slim

WORKDIR /app

# Install dependencies first (layer caching — only re-runs if pyproject.toml changes)
COPY pyproject.toml .
RUN pip install --no-cache-dir .

# Copy application code
COPY app/ app/

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
